<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Run inside the macOS App Sandbox. -->
    <key>com.apple.security.app-sandbox</key>
    <true/>

    <!-- Read/write files the user explicitly selects via open/save panels
         (document import/export, backup, restore). Powerbox grants access to the
         chosen files only — no broad disk access. -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>

    <!-- Deliberately ABSENT: there are no network entitlements
         (com.apple.security.network.client / .server). Under the sandbox this
         means the app cannot make any network connection — enforcing Kontiva's
         "no network, ever" promise at the OS level. -->
</dict>
</plist>
